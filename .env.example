# Server
PORT=4317
APP_BASE_URL=http://localhost:4317
TOKEN_ENCRYPTION_KEY=change-me
SQLITE_FILE=.data/arcpay.sqlite

# Modes
PROVIDER_MODE=mock
TRANSFER_PROVIDER=mock
DEFAULT_SETTLEMENT_RAIL=arc-testnet
SUPPORTED_SETTLEMENT_RAILS=arc-testnet,base-sepolia

# X OAuth 2.0
X_AUTH_MODE=mock
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:4317/auth/x/callback
X_SCOPES=tweet.read tweet.write users.read offline.access
X_WEBHOOK_SECRET=
X_REPLY_ENABLED=0
X_BOT_ACCESS_TOKEN=

# Circle developer-controlled wallets
CIRCLE_WALLETS_ENABLED=0
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
CIRCLE_WALLET_SET_ID=
CIRCLE_USDC_TOKEN_ID=
CIRCLE_WEBHOOK_SECRET=
CIRCLE_WEBHOOK_PUBLIC_KEY_BASE64=

# Arc / Canteen
# Preferred for judging/tracked activity:
#   uv tool install git+https://github.com/the-canteen-dev/ARC-cli
#   arc-canteen login
#   arc-canteen rpc-url
ARC_TESTNET_RPC_URL=
ARC_TESTNET_WS_URL=wss://rpc.testnet.arc.network
ARC_SETTLEMENT_PRIVATE_KEY=

# DeFi / AppKit
DEFI_LIVE_ADAPTERS=0
DEFI_EXECUTION_ENABLED=0
DEFI_MAX_ACTION_USD=25
DEFI_MAX_SLIPPAGE=0.01
LIFI_API_KEY=
ROUTE_PROBE_ENABLED=0
ROUTE_PROBE_WORKER_ENABLED=0
ROUTE_PROBE_INTERVAL_MS=600000
APPKIT_EXECUTION_ENABLED=0
APPKIT_UNIFIED_BALANCE_ENABLED=0
APPKIT_KIT_KEY=

# Background execution
AUTOMATION_WORKER_ENABLED=1
AUTOMATION_WORKER_INTERVAL_MS=10000
AUTOMATION_WORKER_LIMIT=20
WORKFLOW_WORKER_ENABLED=1
WORKFLOW_WORKER_LIMIT=10
BACKGROUND_WORKER_LEASE_ENABLED=1
BACKGROUND_WORKER_LEASE_NAME=bunos-background-worker
BACKGROUND_WORKER_LEASE_TTL_MS=60000

# Gemini agent model
AGENT_MODEL_ENABLED=1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ArcPerps Lite
ARC_PERPS_EXECUTION_ENABLED=0
ARC_PERPS_ORACLE_SYNC_ENABLED=0
ARC_PERPS_ORACLE_SYNC_INTERVAL_MS=300000
ARC_PERPS_USDC_ADDRESS=
ARC_PERPS_ORACLE_ADDRESS=
ARC_PERPS_VAULT_ADDRESS=
ARC_PERPS_MAX_LEVERAGE=3
